# =============================================================================
#  IoT Camera System — MQTT Access Control List (ACL)
#  Phan quyen truy cap topic cho tung tai khoan MQTT
# =============================================================================

# ----- TAI KHOAN: iot_server (Web Server Flask) -----
# Server co QUYEN CAO NHAT: doc/ghi tat ca topic trong he thong
user iot_server
topic readwrite iot/#

# ----- TAI KHOAN: cam_node_01 (ESP32 Camera Node) -----
user cam_node_01
# Camera LANG NGHE lenh dieu khien tu Server
topic read iot/camera/cmd
# Camera GUI phan hoi ACK khi nhan duoc lenh
topic write iot/camera/ack
# Camera GUI trang thai hoat dong (dang chup, dang stream, loi,...)
topic write iot/camera/status
# Camera GUI heartbeat dinh ky (nhip tim bao "toi con song")
topic write iot/system/heartbeat
# Camera GUI log su kien (canh bao, loi phan cung,...)
topic write iot/system/log
# Camera GUI thong bao anh moi da upload thanh cong
topic write iot/notify/new_image

# ----- TAI KHOAN: disp_node_01 (ESP32 Display Node) -----
user disp_node_01
# Display LANG NGHE thong bao anh moi de tai ve hien thi
topic read iot/notify/new_image
# Display LANG NGHE heartbeat cua cac thiet bi khac (de hien thi trang thai)
topic read iot/system/heartbeat
# Display GUI heartbeat cua chinh no
topic write iot/system/heartbeat
# Display GUI log su kien
topic write iot/system/log
# Display GUI trang thai
topic write iot/display/status
